<div class="visor-generar-pdf-wrapper" style="margin-bottom: 1.5rem;">
    <button
        id="btn-generar-pdf"
        class="button button--primary"
        data-nid="{{ nid }}"
        style="display:inline-flex; align-items:center; gap:8px;">
        <span class="material-icons" style="font-size:18px;">picture_as_pdf</span>
        <span id="btn-generar-pdf-label">Generar PDF</span>
    </button>
    <span id="btn-generar-pdf-feedback" style="margin-left:12px; font-size:0.9em; display:none;"></span>
</div>
